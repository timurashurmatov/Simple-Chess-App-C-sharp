<Window x:Class="Chess_UI.Checkmate"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chess_UI"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        Title="Checkmate" Height="300" Width="500">
    <Grid Background="Beige">
        <Label x:Name="Message" HorizontalAlignment="Center" VerticalAlignment="Center"
               FontSize="50" Content="GAME OVER"
               Foreground="SaddleBrown" FontFamily="Consolas"/>
        <Button  HorizontalAlignment="Center" VerticalAlignment="Top"
                 Height="50" Width="120" RenderTransformOrigin="0.493,0.53" Margin="0,208,0,0"
                 Foreground="Beige" Background="SaddleBrown"
                 Content="EXIT"
                 Click="Button_Click"/>
    </Grid>
</Window>
