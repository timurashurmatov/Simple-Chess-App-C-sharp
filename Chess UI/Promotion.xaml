<Window x:Class="Chess_UI.Promotion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chess_UI"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        Title="Promotion" Height="200" Width="500">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Button x:Name="KnightBtn" Grid.Column="0" Height="140" Width="120" Content="♘" FontSize="100" Background="Beige" Click="ButtonClick"/>
        <Button x:Name="BishopBtn" Grid.Column="1" Height="140" Width="120" Content="♗" FontSize="100" Background="Beige" Click="ButtonClick"/>
        <Button x:Name="RookBtn" Grid.Column="2" Height="140" Width="120" Content="♖" FontSize="100" Background="Beige" Click="ButtonClick"/>
        <Button x:Name="QueenBtn" Grid.Column="3" Height="140" Width="120" Content="♕" FontSize="100" Background="Beige" Click="ButtonClick"/>
    </Grid>
</Window>
